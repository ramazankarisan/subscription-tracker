{
  "name": "subscription-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit",
    "knip": "knip --production --strict",
    "secretlint": "secretlint --secretlintignore .gitignore \"**/*\"",
    "preview": "vite preview",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "date-fns": "^4.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^9.3.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "knip": "^5.64.1",
    "lefthook": "^1.13.6",
    "oxlint": "^1.71.0",
    "prettier": "^3.9.4",
    "secretlint": "^9.3.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0"
  }
}
