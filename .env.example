# Copy to `.env` and fill in from the Supabase dashboard.
# Easiest: click "Connect" (top of the dashboard) → App Frameworks tab, which
# shows both values together. Both are PUBLIC by design (Row Level Security
# protects the data), so they're safe in the built app / GitHub Actions Variables.

# https://<ref>.supabase.co  (<ref> = the string after /project/ in the URL bar)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Settings → API Keys: new projects show a "Publishable key" (sb_publishable_...);
# older projects show the legacy "anon public" key (eyJ...). Either works.
VITE_SUPABASE_ANON_KEY=YOUR-PUBLISHABLE-OR-ANON-KEY
